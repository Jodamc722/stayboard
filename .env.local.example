# Supabase — get these from your Supabase project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (for admin operations). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Guesty Open API — paste when you find them. Mock mode runs in the meantime.
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
GUESTY_BASE_URL=https://open-api.guesty.com/v1
NEXT_PUBLIC_GUESTY_MOCK_MODE=true
